# LiveKit server the worker registers with (same project the API server mints tokens for)
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# OpenAI Realtime (speech-to-speech model inside the agent session)
OPENAI_API_KEY=

# --- optional overrides (keep in sync with opentxt/server) ---
# OPENAI_REALTIME_MODEL=gpt-realtime
# OPENAI_REALTIME_VOICE=marin
