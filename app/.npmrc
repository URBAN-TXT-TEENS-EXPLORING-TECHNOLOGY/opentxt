# React Native/Metro needs a flat node_modules; pnpm's default symlinked
# store breaks autolinking. (npm warns it doesn't know this key - harmless,
# it's a pnpm setting.)
node-linker=hoisted

# The global ~/.npmrc sets min-release-age=2 (days). Expo ships SDK patch
# releases faster than that and expo-doctor pins to them; exclude the Expo
# family from the gate.
minimum-release-age-exclude[]=expo
minimum-release-age-exclude[]=expo-*
minimum-release-age-exclude[]=@expo/*
