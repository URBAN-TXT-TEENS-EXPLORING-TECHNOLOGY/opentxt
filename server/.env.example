# --- required ---
# JWT signing secret for client auth tokens (any long random string)
AUTH_SECRET=

# OpenAI: text chat + STT + Realtime voice (client secrets)
OPENAI_API_KEY=

# --- LiveKit voice mode (optional until you use /api/voice/livekit) ---
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# --- optional overrides ---
# DATABASE_PATH=./data/opentxt.db
# OPENAI_CHAT_MODEL=gpt-4.1-mini
# OPENAI_CHAT_MODELS=gpt-4.1-mini,gpt-4.1
# OPENAI_STT_MODEL=whisper-1
# OPENAI_REALTIME_MODEL=gpt-realtime-2.1
# OPENAI_REALTIME_VOICE=marin
